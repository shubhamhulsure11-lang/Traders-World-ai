{
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 0 * * *"
    },
        {
                "path": "/api/news-monitor",
      "schedule": "0 8 * * *"            }  ]
}
,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    }
  ]
