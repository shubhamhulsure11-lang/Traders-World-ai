# TradeLens AI - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE (Free tier at supabase.com)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# TELEGRAM BOT (Optional - for alerts)
# How to create:
# 1. Open Telegram, search @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token below
# 4. Get your chat ID by messaging @userinfobot
# ============================================
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_NAME=TradeLens AI
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================
# NOTE: The dashboard works WITHOUT any env vars
# for the demo version. Add Supabase only when
# you want to persist data or add alerts.
# ============================================
